<!doctype html>
<html lang="zh-CN">

<head>
    <%- include('partials/head', { title }) %>
</head>

<body>
    <%- include('partials/navbar') %>

        <main class="max-w-5xl mx-auto px-4 py-10">
            <div class="flex items-center justify-center min-h-[60vh]">
                <div
                    class="w-full max-w-lg p-8 border-2 border-black bg-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] rounded-none">
                    <% if (action==='public' ) { %>
                        <div class="text-center">
                            <div class="text-2xl font-serif font-bold">提交成功</div>
                            <div class="mt-2 font-mono text-xs text-neutral-500">
                                你的公开海龟汤已进入 <span class="font-bold">待审核</span> 状态。
                            </div>
                            <div class="mt-6 flex justify-center gap-2">
                                <a class="btn-sketch" href="/soups/<%= soupId %>">预览</a>
                                <a class="btn-sketch-primary" href="/">返回公开汤池</a>
                            </div>
                        </div>

                        <% } else if (action==='private' ) { %>
                            <div class="text-center">
                                <div class="text-2xl font-serif font-bold">私密汤已创建</div>
                                <div class="mt-2 font-mono text-xs text-neutral-500">
                                    分享码 24 小时有效，请复制并发送给好友。
                                </div>

                                <div
                                    class="mt-6 border-2 border-black p-4 font-mono text-sm flex items-center justify-between">
                                    <span id="shareCode">
                                        <%= share.code %>
                                    </span>
                                    <button id="copyBtn" class="btn-sketch" type="button">复制</button>
                                </div>

                                <div class="mt-3 font-mono text-xs text-neutral-500">
                                    到期时间：<%= formatDateTime(share.expiresAt) %>
                                </div>

                                <div class="mt-4 border border-neutral-200 p-4 text-left">
                                    <div class="font-mono text-xs text-neutral-500 mb-2">分享入口：</div>
                                    <a class="underline" href="/share/<%= share.code %>">/share/<%= share.code %></a>
                                </div>

                                <div class="mt-6 flex justify-center gap-2">
                                    <a class="btn-sketch" href="/soups/<%= soupId %>">预览</a>
                                    <a class="btn-sketch-primary" href="/">返回公开汤池</a>
                                </div>
                            </div>

                            <script>
                                (function () {
                                    const btn = document.getElementById('copyBtn');
                                    const codeEl = document.getElementById('shareCode');
                                    if (!btn || !codeEl) return;
                                    btn.addEventListener('click', async () => {
                                        try {
                                            await navigator.clipboard.writeText(codeEl.textContent.trim());
                                            btn.textContent = '已复制';
                                            setTimeout(() => (btn.textContent = '复制'), 1200);
                                        } catch {
                                            btn.textContent = '复制失败';
                                            setTimeout(() => (btn.textContent = '复制'), 1200);
                                        }
                                    });
                                })();
                            </script>

                            <% } else { %>
                                <div class="text-center">
                                    <div class="text-2xl font-serif font-bold">草稿已保存</div>
                                    <div class="mt-2 font-mono text-xs text-neutral-500">
                                        草稿不会出现在公开汤池，你可以在“我的汤库”继续管理。
                                    </div>
                                    <div class="mt-6 flex justify-center gap-2">
                                        <a class="btn-sketch" href="/soups/<%= soupId %>">预览草稿</a>
                                        <a class="btn-sketch-primary" href="/soups/create">继续写</a>
                                    </div>
                                </div>
                                <% } %>
                </div>
            </div>
        </main>
</body>

</html>