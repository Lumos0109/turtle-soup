<!doctype html>
<html lang="zh-CN">

<head>
	<%- include('partials/head') %>
</head>

<body>
	<%- include('partials/navbar') %>

	<%
		const queryState = (typeof query !== 'undefined' && query) ? query : {};
		const viewer = (typeof currentUser !== 'undefined' && currentUser) ? currentUser : null;
		const soupList = (typeof soups !== 'undefined' && Array.isArray(soups)) ? soups : [];
		const tagList = (typeof tags !== 'undefined' && Array.isArray(tags)) ? tags : [];
		const selectedTagList = (typeof selectedTags !== 'undefined' && Array.isArray(selectedTags)) ? selectedTags : [];

		const selectedTagIds = String(queryState.tagsParam || '')
			.split(',')
			.map((id) => id.trim())
			.filter(Boolean);

		const sortValue = queryState.sort || '';
		const sortText =
			sortValue === 'hot_desc'
				? '热度↓'
				: sortValue === 'hot_asc'
					? '热度↑'
					: '热度';

		const ratingSortText =
			sortValue === 'rating_desc'
				? '评分↓'
				: sortValue === 'rating_asc'
					? '评分↑'
					: '评分';

		const hideReadValue = queryState.hideRead ? '1' : '';
	%>

	<main class="max-w-5xl mx-auto px-4 py-8">
		<section class="mb-12 text-center space-y-4">
			<h1 class="text-4xl md:text-6xl font-serif font-bold tracking-tight">
				海龟汤
			</h1>

			<p class="text-lg text-neutral-600 max-w-2xl mx-auto">
				阅读卡片上的故事，先猜真相，点击卡片即可翻转查看汤底。
			</p>

			<p class="text-lg text-neutral-600 max-w-2xl mx-auto">
				（查看汤底后才能点赞或留言喔）
			</p>
		</section>

		<div class="home-announcement-soft">
			<%- include('partials/announcement_widget') %>
		</div>


		<div class="mb-8 w-full">
			<form id="homeSearchForm" action="/" method="get">
				<div class="relative">
					<div class="border-2 border-black bg-white h-14 flex items-center px-5 pr-14 rounded-full transition-colors">
						<svg
							class="w-5 h-5 text-neutral-400 shrink-0"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							aria-hidden="true"
						>
							<path
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M21 21l-4.3-4.3m1.8-5.2a7 7 0 11-14 0 7 7 0 0114 0z"
							/>
						</svg>

						<input
							id="qInput"
							name="q"
							class="ml-3 flex-1 h-full outline-none text-lg bg-transparent"
							placeholder="搜索标题 / 汤面 / 作者..."
							value="<%= queryState.q || '' %>"
							autocomplete="off"
						/>

						<input
							id="tagsInput"
							type="hidden"
							name="tags"
							value="<%= selectedTagIds.join(',') %>"
						/>

						<input
							id="sortInput"
							type="hidden"
							name="sort"
							value="<%= sortValue %>"
						/>

						<% if (viewer) { %>
							<input
								id="hideReadInput"
								type="hidden"
								name="hide_read"
								value="<%= hideReadValue %>"
							/>
						<% } %>
					</div>

					<button
						id="filterBtn"
						type="button"
						class="absolute right-4 top-1/2 -translate-y-1/2 inline-flex h-9 w-9 items-center justify-center text-neutral-500 hover:text-black transition"
						aria-label="筛选标签"
						aria-controls="filterPanel"
						aria-expanded="false"
						title="筛选"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="22"
							height="22"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="lucide lucide-funnel-icon lucide-funnel"
							aria-hidden="true"
						>
							<path d="M10 20a1 1 0 0 0 .553.895l2 1A1 1 0 0 0 14 21v-7a2 2 0 0 1 .517-1.341L21.74 4.67A1 1 0 0 0 21 3H3a1 1 0 0 0-.742 1.67l7.225 7.989A2 2 0 0 1 10 14z" />
						</svg>
					</button>
				</div>
			</form>

			<div
				id="filterPanel"
				class="hidden mt-3 border border-neutral-200 bg-white p-4 rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.06)]"
			>
				<div class="flex items-center justify-between mb-3">
					<div class="font-mono text-xs text-neutral-500">
						多选标签筛选
					</div>

					<div class="flex items-center gap-2">
						<% if (viewer) { %>
							<button
								id="hideReadBtn"
								type="button"
								class="flex items-center gap-1 font-mono text-xs border border-neutral-300 rounded-full px-3 py-1.5 hover:border-black hover:bg-black hover:text-white transition <%= queryState.hideRead ? 'bg-black text-white border-black' : '' %>"
							>
								<span id="hideReadIcon"><%= queryState.hideRead ? '✓' : '' %></span>
								<span>隐藏已读</span>
							</button>
						<% } %>

						<button
							id="sortBtn"
							type="button"
							class="flex items-center gap-1 font-mono text-xs border border-neutral-300 rounded-full px-3 py-1.5 hover:border-black hover:bg-black hover:text-white transition"
						>
							<span id="sortIcon">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="16"
									height="16"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									class="lucide lucide-heart-icon lucide-heart"
									aria-hidden="true"
								>
									<path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5" />
								</svg>
							</span>

							<span id="sortText"><%= sortText %></span>
						</button>

						<button
							id="ratingSortBtn"
							type="button"
							class="flex items-center gap-1 font-mono text-xs border border-neutral-300 rounded-full px-3 py-1.5 hover:border-black hover:bg-black hover:text-white transition"
						>
							<span>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="16"
									height="16"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									aria-hidden="true"
								>
									<path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.12 2.12 0 0 0 1.595 1.16l5.166.751a.53.53 0 0 1 .294.904l-3.738 3.644a2.12 2.12 0 0 0-.611 1.878l.882 5.145a.53.53 0 0 1-.77.559l-4.62-2.429a2.12 2.12 0 0 0-1.973 0l-4.62 2.429a.53.53 0 0 1-.77-.56l.882-5.144a2.12 2.12 0 0 0-.611-1.878L2.16 9.79a.53.53 0 0 1 .294-.904l5.165-.751a2.12 2.12 0 0 0 1.597-1.16z" />
								</svg>
							</span>

							<span id="ratingSortText"><%= ratingSortText %></span>
						</button>
					</div>
				</div>

				<div class="flex flex-wrap gap-2">
					<% tagList.forEach((t) => { %>
						<%
							const tagId = String(t.id);
							const checked = selectedTagIds.includes(tagId);
						%>

						<label class="flex items-center gap-2 border border-neutral-200 rounded-full px-3 py-2 font-mono text-xs cursor-pointer hover:border-black transition">
							<input
								class="tagCheck"
								type="checkbox"
								value="<%= tagId %>"
								<%= checked ? 'checked' : '' %>
							/>
							<span><%= t.name %></span>
						</label>
					<% }) %>
				</div>

				<div class="mt-4 flex items-center justify-end gap-2">
					<button id="filterClearBtn" type="button" class="btn-sketch">
						清空
					</button>

					<button id="filterApplyBtn" type="button" class="btn-sketch-primary">
						确认
					</button>
				</div>
			</div>

			<div id="selectedChips" class="mt-3 flex flex-wrap justify-center gap-2">
				<% selectedTagList.forEach((t) => { %>
					<span class="chip group inline-flex items-center gap-2 px-3 py-1 border border-neutral-300 rounded-full font-mono text-xs bg-white">
						<span><%= t.name %></span>

						<button
							type="button"
							class="chip-remove hidden group-hover:inline-flex"
							data-tag-id="<%= t.id %>"
							aria-label="移除标签：<%= t.name %>"
						>
							×
						</button>
					</span>
				<% }) %>
			</div>
		</div>

		<% if (soupList.length === 0) { %>
			<div class="text-center py-20 border-2 border-dashed border-neutral-300 rounded-lg">
				<p class="text-neutral-500 font-mono">
					没有找到海龟汤。
				</p>

				<a href="/soups/create" class="text-black underline mt-2 block font-medium">
					要不要上传一个？
				</a>
			</div>
		<% } else { %>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
				<% soupList.forEach((s) => { %>
					<% const soupTagNames = String(s.tag_names || '').split('、').filter(Boolean); %>
					<a href="/soups/<%= s.id %>" class="cursor-pointer group block">
						<div class="bg-white border-2 border-black p-6 h-64 flex flex-col justify-between shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] group-hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] group-hover:-translate-y-1 transition-all duration-200">
							<div>
								<div class="mb-2 flex items-start justify-between gap-3">
									<h3 class="text-xl font-serif font-bold line-clamp-2">
										<%= s.title || '' %>
									</h3>

									<span class="shrink-0 inline-flex items-center gap-1 rounded-full border border-neutral-300 bg-neutral-50 px-2 py-1 font-mono text-[11px] text-neutral-700">
										<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
											<path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.12 2.12 0 0 0 1.595 1.16l5.166.751a.53.53 0 0 1 .294.904l-3.738 3.644a2.12 2.12 0 0 0-.611 1.878l.882 5.145a.53.53 0 0 1-.77.559l-4.62-2.429a2.12 2.12 0 0 0-1.973 0l-4.62 2.429a.53.53 0 0 1-.77-.56l.882-5.144a2.12 2.12 0 0 0-.611-1.878L2.16 9.79a.53.53 0 0 1 .294-.904l5.165-.751a2.12 2.12 0 0 0 1.597-1.16z" />
										</svg>
										<span><%= Number(s.rating_count || 0) > 0 ? Number(s.rating_avg || 0).toFixed(1) : '暂无评分' %></span>
									</span>
								</div>

								<% if (soupTagNames.length > 0) { %>
									<div class="mb-2 flex flex-wrap gap-1.5">
										<% soupTagNames.slice(0, 4).forEach((tagName) => { %>
											<span class="inline-flex rounded-full border border-neutral-200 bg-neutral-50 px-2 py-0.5 font-mono text-[10px] text-neutral-500"><%= tagName %></span>
										<% }) %>
									</div>
								<% } %>

								<p class="text-neutral-600 line-clamp-2 font-medium">
									<%= s.surface || '' %>
								</p>
							</div>

							<div class="flex items-center justify-between pt-4 border-t border-neutral-100 mt-4 text-xs font-mono text-neutral-500">
								<span>作者：<%= s.author_name || 'Unknown' %></span>

								<span class="flex items-center gap-4">
									<span class="inline-flex items-center gap-1">
										<svg
											width="14"
											height="14"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
											aria-hidden="true"
										>
											<path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z" />
										</svg>

										<span><%= s.like_count || 0 %></span>
									</span>

									<span class="group-hover:text-black group-hover:underline">
										Read more →
									</span>
								</span>
							</div>
						</div>
					</a>
				<% }) %>
			</div>
		<% } %>
	</main>

	<script defer src="/js/home.js?v=20260604-author-search"></script>

	<%- include('partials/feedback_widget') %>
</body>

</html>