				<% } %>
			</div>
		</div>


		<div id="ratingModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 px-4">
			<div class="w-full max-w-md rounded-2xl border border-neutral-200 bg-white shadow-[0_20px_60px_rgba(0,0,0,0.22)]">
				<div class="flex items-center justify-between gap-3 border-b border-neutral-100 px-5 py-4">
					<div>
						<div class="font-serif text-xl font-bold">给这碗汤打分</div>
						<div class="mt-1 font-mono text-xs text-neutral-500">1 颗星 = 2 分，最高 10 分</div>
					</div>

					<button type="button" class="js-rating-close nb-tooltip inline-flex items-center justify-center p-1 hover:opacity-70" data-tip="关闭" aria-label="关闭打分弹窗">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="12" cy="12" r="10"/>
							<path d="m15 9-6 6"/>
							<path d="m9 9 6 6"/>
						</svg>
					</button>
				</div>

				<div class="px-5 py-5">
					<div class="js-rating-hint mb-4 hidden rounded-xl border border-neutral-200 bg-neutral-50 px-3 py-2 font-mono text-xs text-neutral-600">
						你已经给这个汤打过分了哦，再次打分会覆盖上一次打分情况~
					</div>

					<div class="flex items-center justify-center gap-2" id="ratingStars" data-current-score="<%= currentUserRating || '' %>">
						<% [2, 4, 6, 8, 10].forEach((score, index) => { %>
							<button type="button" class="js-rating-star text-neutral-300 transition hover:scale-110" data-score="<%= score %>" aria-label="<%= score %> 分">
								<svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.12 2.12 0 0 0 1.595 1.16l5.166.751a.53.53 0 0 1 .294.904l-3.738 3.644a2.12 2.12 0 0 0-.611 1.878l.882 5.145a.53.53 0 0 1-.77.559l-4.62-2.429a2.12 2.12 0 0 0-1.973 0l-4.62 2.429a.53.53 0 0 1-.77-.56l.882-5.144a2.12 2.12 0 0 0-.611-1.878L2.16 9.79a.53.53 0 0 1 .294-.904l5.165-.751a2.12 2.12 0 0 0 1.597-1.16z" />
								</svg>
							</button>
						<% }) %>
					</div>

					<div id="ratingSelectedText" class="mt-3 text-center font-mono text-sm text-neutral-500">
						请选择评分
					</div>

					<div class="mt-5 flex items-center justify-end gap-2">
						<button type="button" class="js-rating-close btn-sketch">取消</button>
						<button type="button" id="ratingSubmitBtn" class="btn-sketch-primary disabled:opacity-50" disabled>确认打分</button>
					</div>
				</div>
			</div>
		</div>
		<% if (soup.has_host_manual && (soup.host_manual || '').trim()) { %>
			<div id="hostManualModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 px-4">
				<div class="w-full max-w-2xl max-h-[80vh] border-2 border-black bg-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] flex flex-col">
					<div class="flex items-center justify-between gap-3 border-b-2 border-black px-5 py-4">
						<div class="flex items-center gap-2 font-serif font-bold text-xl">
							<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M12 7v14"/><path d="M16 12h2"/><path d="M16 8h2"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/><path d="M6 12h2"/><path d="M6 8h2"/>
							</svg>
							主持人手册
						</div>
						<button type="button" class="js-host-manual-close inline-flex items-center justify-center p-1 hover:opacity-70" aria-label="关闭主持人手册">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<circle cx="12" cy="12" r="10"/>
								<path d="m15 9-6 6"/>
								<path d="m9 9 6 6"/>
							</svg>
						</button>
					</div>
					<div class="overflow-y-auto p-5 custom-scrollbar">
						<div class="whitespace-pre-wrap leading-relaxed text-neutral-800"><%= (soup.host_manual || '').trim() %></div>
					</div>
				</div>
			</div>
		<% } %>
		<div id="nb-toast"
			class="fixed left-1/2 bottom-6 -translate-x-1/2 bg-black text-white px-3 py-2 rounded opacity-0 transition-opacity">
		</div>

	<script src="/js/soup-export.js" defer></script>

	<script>
	(function () {
		const facilitatorModal = document.getElementById('facilitatorModal');
		const openBtns = document.querySelectorAll('.js-facilitator-open');
		const closeBtns = document.querySelectorAll('.js-facilitator-close');
		const surfaceBtn = document.getElementById('facilitatorSurfaceBtn');
		const surfacePanel = document.getElementById('facilitatorSurfacePanel');

		function openFacilitatorModal() {
			if (!facilitatorModal) return;
			facilitatorModal.classList.remove('hidden');
			facilitatorModal.classList.add('flex');
			document.body.classList.add('overflow-hidden');

			const inputEl = document.getElementById('facilitator-input');
			if (inputEl) {
				setTimeout(() => inputEl.focus(), 50);
			}
		}

		function closeFacilitatorModal() {
			if (!facilitatorModal) return;
			facilitatorModal.classList.add('hidden');
			facilitatorModal.classList.remove('flex');
			document.body.classList.remove('overflow-hidden');
		}

		openBtns.forEach((btn) => {
			btn.addEventListener('click', openFacilitatorModal);
		});

		if (surfaceBtn && surfacePanel) {
			surfaceBtn.addEventListener('click', () => {
				const isOpen = !surfacePanel.classList.contains('hidden');
				surfacePanel.classList.toggle('hidden', isOpen);
				surfaceBtn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
			});
		}

		closeBtns.forEach((btn) => {
			btn.addEventListener('click', closeFacilitatorModal);
		});

		if (facilitatorModal) {
			facilitatorModal.addEventListener('click', (event) => {
				if (event.target === facilitatorModal) {
					closeFacilitatorModal();
				}
			});
		}

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && facilitatorModal && !facilitatorModal.classList.contains('hidden')) {
				closeFacilitatorModal();
			}
		});
	})();
	</script>

	<% if (currentUser) { %>
	<script>
	(function () {
		const soupId = <%= soup.id %>;
		const formEl = document.getElementById('facilitator-form');
		const inputEl = document.getElementById('facilitator-input');
		const messagesEl = document.getElementById('facilitator-messages');
		const submitBtn = document.getElementById('facilitator-submit');
		if (!formEl || !inputEl || !messagesEl || !submitBtn) return;

		let history = [];

		function esc(str) {
			return String(str || '')
				.replace(/&/g, '&amp;')
				.replace(/</g, '&lt;')
				.replace(/>/g, '&gt;');
		}

		function botIconSvg() {
			return `
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M12 8V4H8"/>
					<rect width="16" height="12" x="4" y="8" rx="2"/>
					<path d="M2 14h2"/>
					<path d="M20 14h2"/>
					<path d="M15 13v2"/>
					<path d="M9 13v2"/>
				</svg>
			`;
		}

		function answerClass(text) {
			if (/^是/.test(text) && !/部分/.test(text)) return 'border-green-500 bg-green-50 text-green-900';
			if (/^否/.test(text)) return 'border-red-500 bg-red-50 text-red-900';
			if (/部分/.test(text)) return 'border-amber-500 bg-amber-50 text-amber-900';
			return 'border-neutral-300 bg-white text-neutral-700';
		}

		function scrollToBottom() {
			messagesEl.scrollTop = messagesEl.scrollHeight;
		}

		function appendMessage(role, content) {
			const hint = document.getElementById('facilitator-empty-hint');
			if (hint) hint.remove();

			const wrap = document.createElement('div');

			if (role === 'user') {
				wrap.className = 'mb-4 flex justify-end';
				wrap.innerHTML = `
					<div class="max-w-[78%] rounded-2xl rounded-tr-sm bg-black px-4 py-3 text-sm leading-relaxed text-white break-words shadow-[3px_3px_0px_0px_rgba(0,0,0,0.2)]">
						${esc(content)}
					</div>
				`;
			} else {
				const cls = answerClass(content);
				wrap.className = 'mb-4 flex items-start gap-3 justify-start';
				wrap.innerHTML = `
					<div class="shrink-0 inline-flex h-9 w-9 items-center justify-center rounded-full border-2 border-black bg-white">
						${botIconSvg()}
					</div>
					<div class="max-w-[78%] rounded-2xl rounded-tl-sm border-2 px-4 py-3 text-sm leading-relaxed break-words shadow-[3px_3px_0px_0px_rgba(0,0,0,1)] ${cls}">
						${esc(content)}
					</div>
				`;
			}

			messagesEl.appendChild(wrap);
			scrollToBottom();
			return wrap;
		}

		function appendLoading() {
			const hint = document.getElementById('facilitator-empty-hint');
			if (hint) hint.remove();

			const wrap = document.createElement('div');
			wrap.className = 'mb-4 flex items-start gap-3 justify-start js-facilitator-loading';
			wrap.innerHTML = `
				<div class="shrink-0 inline-flex h-9 w-9 items-center justify-center rounded-full border-2 border-black bg-white">
					${botIconSvg()}
				</div>
				<div class="rounded-2xl rounded-tl-sm border-2 border-neutral-300 bg-white px-4 py-3 text-sm text-neutral-400 shadow-[3px_3px_0px_0px_rgba(0,0,0,1)]">
					<span class="animate-pulse">正在思考…</span>
				</div>
			`;
			messagesEl.appendChild(wrap);
			scrollToBottom();
			return wrap;
		}

		formEl.addEventListener('submit', async function (e) {
			e.preventDefault();

			const question = inputEl.value.trim();
			if (!question) return;

			inputEl.value = '';
			submitBtn.disabled = true;

			appendMessage('user', question);
			const loadingEl = appendLoading();

			try {
				const resp = await fetch(`/soups/${soupId}/ask`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ question, history }),
				});

				loadingEl.remove();

				if (!resp.ok) {
					const err = await resp.json().catch(() => ({}));
					appendMessage('assistant', err.message || '请求失败');
					return;
				}

				const data = await resp.json();

				history.push({ role: 'user', content: question });
				history.push({ role: 'assistant', content: data.answer });

				appendMessage('assistant', data.answer);
			} catch (_) {
				loadingEl.remove();
				appendMessage('assistant', '网络错误，请重试');
			} finally {
				submitBtn.disabled = false;
				inputEl.focus();
			}
		});
	})();
	</script>
	<% } %>
</body>

</html>