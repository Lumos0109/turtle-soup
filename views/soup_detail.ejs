						</div>
					</div>

					<div class="flex shrink-0 items-center gap-2">
						<button type="button" id="facilitatorSurfaceBtn" class="rounded-full border border-neutral-300 bg-white px-3 py-1.5 font-mono text-xs hover:border-black hover:bg-black hover:text-white" aria-expanded="false">汤面</button>
						<button type="button" class="js-facilitator-close inline-flex items-center justify-center p-1 hover:opacity-70" aria-label="关闭AI主持人">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<circle cx="12" cy="12" r="10"/>
								<path d="m15 9-6 6"/>
								<path d="m9 9 6 6"/>
							</svg>
						</button>
