						<div class="max-w-sm border-2 border-black bg-white p-6 text-center shadow-[5px_5px_0px_0px_rgba(0,0,0,1)]">
							<div class="mx-auto mb-4 inline-flex h-12 w-12 items-center justify-center rounded-full border-2 border-black bg-neutral-100">
								<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
