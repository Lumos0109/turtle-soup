<% if (activeAnnouncement) { %>
  <div class="announcement-widget-soft mb-8 w-full">
    <style>
      .announcement-widget-soft .ann-soft-btn,
      .announcement-widget-soft .btn-sketch {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgb(212 212 212) !important;
        border-radius: 9999px !important;
        background: #fff !important;
        color: rgb(23 23 23) !important;
        box-shadow: none !important;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        line-height: 1;
        transition: all 150ms ease;
      }

      .announcement-widget-soft .ann-soft-btn:hover,
      .announcement-widget-soft .btn-sketch:hover {
        border-color: #000 !important;
        background: #000 !important;
        color: #fff !important;
      }
    </style>

    <section id="announcementBox" class="w-full">
      <div class="border border-neutral-200 bg-white p-3 rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.06)]">
        <div class="flex items-center gap-3">
          <!-- 左侧铃铛 -->
          <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-neutral-300 bg-white text-neutral-700">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M10.268 21a2 2 0 0 0 3.464 0" />
              <path d="M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326" />
            </svg>
          </span>

          <!-- 中间公告内容，只有一行灰色卡片 -->
          <button
            type="button"
            class="announcement-open flex-1 min-w-0 rounded-2xl border border-neutral-100 bg-neutral-50/80 px-2 py-1 text-left transition hover:border-neutral-300 hover:bg-white"
            data-id="<%= activeAnnouncement.id %>"
          >
            <span class="font-mono text-sm sm:text-base text-neutral-900">
              <span class="font-bold">公告：</span>
              <span class="truncate inline-block align-bottom max-w-[180px] sm:max-w-[520px] md:max-w-[720px]">
                <%= activeAnnouncement.title %>
              </span>
            </span>
          </button>

          <!-- 右侧历史按钮 -->
          <button
            type="button"
            id="annHistoryBtn"
            class="ann-soft-btn shrink-0 px-4 py-2 text-xs"
          >
            历史
          </button>
        </div>

        <!-- 历史面板仍然保留，点“历史”后展开 -->
        <div
          id="annHistoryPanel"
          class="hidden mt-3 rounded-xl border border-neutral-100 bg-neutral-50/60 p-3"
        >
          <div id="annHistoryList" class="space-y-2"></div>

          <div class="mt-3 flex items-center justify-between font-mono text-xs">
            <button type="button" id="annPrevBtn" class="ann-soft-btn px-3 py-1">
              上一页
            </button>

            <span id="annPageText" class="text-neutral-500">
              1 / 1
            </span>

            <button type="button" id="annNextBtn" class="ann-soft-btn px-3 py-1">
              下一页
            </button>
          </div>
        </div>
      </div>
    </section>

    <script id="announcementData" type="application/json"><%- JSON.stringify(announcements || []).replace(/</g, '\\u003c') %></script>

    <div id="annModal" class="hidden fixed inset-0 z-[70]">
      <div id="annMask" class="absolute inset-0 bg-black/30"></div>

      <div class="absolute left-1/2 top-1/2 w-[92vw] max-w-md -translate-x-1/2 -translate-y-1/2 overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-[0_20px_60px_rgba(0,0,0,0.18)]">
        <div class="flex items-center justify-between gap-3 border-b border-neutral-100 px-4 py-3">
          <div class="font-serif font-bold text-xl" id="annModalTitle">
            公告
          </div>

          <button type="button" id="annCloseBtn" class="ann-soft-btn px-3 py-1.5 text-xs">
            关闭
          </button>
        </div>

        <div
          class="p-4 whitespace-pre-wrap leading-relaxed text-neutral-800"
          id="annModalContent"
        ></div>
      </div>
    </div>

    <script defer src="/js/announcement.js"></script>
  </div>
<% } %>