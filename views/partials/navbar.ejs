							<a href="/auth/login" class="btn-sketch-primary">LOGIN</a>
							<% } %>
		</nav>
	</div>
	<% if (currentUser) { %>
		<!-- 手机端快捷菜单：避免顶部导航被挤爆 -->
		<div class="sm:hidden border-t border-neutral-200 bg-white">
			<div class="max-w-5xl mx-auto px-4 py-2 overflow-x-auto">
				<div class="flex items-center gap-2 min-w-max">
					<a href="/soups/create"
						class="btn-sketch font-mono text-xs">
						新建海龟汤
					</a>

					<a href="/my"
						class="btn-sketch font-mono text-xs">
						我的汤库
					</a>

					<a href="/messages"
						class="btn-sketch font-mono text-xs">
						消息<% if ((unreadCount || 0) > 0) { %>（<%= unreadCount > 99 ? '99+' : unreadCount %>）<% } %>
					</a>

					<% if (currentUser.role==='admin' ) { %>
						<a href="/admin"
							class="btn-sketch font-mono text-xs">
							后台
						</a>
						<% } %>
				</div>
			</div>
		</div>
		<% } %>
</header>

<script>
(function () {
	const wrap = document.getElementById('siteSupportMenu');
	const btn = document.getElementById('siteSupportBtn');
	const panel = document.getElementById('siteSupportPanel');
	const copyBtn = document.getElementById('copyQQGroupBtn');

	if (!wrap || !btn || !panel) return;

	function showToast(message) {
		let toast = document.getElementById('nb-global-toast');

		if (!toast) {
			toast = document.createElement('div');
			toast.id = 'nb-global-toast';
			toast.className = 'fixed left-1/2 bottom-6 z-[120] -translate-x-1/2 rounded bg-black px-3 py-2 font-mono text-xs text-white opacity-0 transition-opacity';
			document.body.appendChild(toast);
		}

		toast.textContent = message;
		toast.classList.remove('opacity-0');
		toast.classList.add('opacity-100');

		window.clearTimeout(toast._timer);
		toast._timer = window.setTimeout(() => {
			toast.classList.add('opacity-0');
			toast.classList.remove('opacity-100');
		}, 1800);
	}

	async function copyText(text) {
		if (navigator.clipboard && window.isSecureContext) {
			await navigator.clipboard.writeText(text);
			return;
		}

		const textarea = document.createElement('textarea');
		textarea.value = text;
		textarea.setAttribute('readonly', '');
		textarea.style.position = 'fixed';
		textarea.style.left = '-9999px';
		textarea.style.top = '-9999px';

		document.body.appendChild(textarea);
		textarea.focus();
		textarea.select();

		const ok = document.execCommand('copy');
		document.body.removeChild(textarea);

		if (!ok) throw new Error('copy failed');
	}

	function openPanel() {
		panel.classList.remove('hidden');
		btn.setAttribute('aria-expanded', 'true');
	}

	function closePanel() {
		panel.classList.add('hidden');
		btn.setAttribute('aria-expanded', 'false');
	}

	function togglePanel() {
		if (panel.classList.contains('hidden')) {
			openPanel();
		} else {
			closePanel();
		}
	}

	btn.addEventListener('click', (event) => {
		event.preventDefault();
		event.stopPropagation();
		togglePanel();
	});

	if (copyBtn) {
		copyBtn.addEventListener('click', async (event) => {
			event.preventDefault();
			event.stopPropagation();

			const text = copyBtn.getAttribute('data-copy-text') || '684121136';

			try {
				await copyText(text);
				showToast('已复制QQ群号：' + text);
			} catch (error) {
				console.error(error);
				showToast('复制失败，请手动复制群号：' + text);
			}
		});
	}

	document.addEventListener('click', (event) => {
		if (!wrap.contains(event.target)) {
			closePanel();
		}
	});

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') {
			closePanel();
		}
	});
})();
</script>