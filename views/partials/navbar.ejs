							</div>
						</button>

						<a
							href="https://www.ifdian.net/a/lumosWinnie"
							target="_blank"
							rel="noopener noreferrer"
							class="block rounded-xl border border-neutral-200 bg-neutral-50 px-3 py-3 transition hover:border-black hover:bg-white"
						>
							<div class="flex items-start gap-3">
								<span class="mt-0.5 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-black text-white">
									<!-- donate icon -->
<svg
										width="19"
										height="19"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										aria-hidden="true"
									>
										<path d="M11 15h2a2 2 0 1 0 0-4h-3c-.6 0-1.1.2-1.4.6L3 17" />
										<path d="m7 21 1.6-1.4c.3-.4.8-.6 1.4-.6h4c1.1 0 2.1-.4 2.8-1.2l4.6-4.4a2 2 0 0 0-2.75-2.91l-4.2 3.9" />
										<path d="m2 16 6 6" />
