									<span class="mt-1 block text-xs leading-relaxed text-neutral-500">
										查看项目源码、提交 issue，或者关注网站功能更新。
									</span>
								</span>
							</div>
						</a>
					</div>
				</div>
			</div>

			<% if (currentUser) { %>
				<!-- NEW SOUP（原版是 outline 风格按钮 + plus icon，移动端隐藏） -->
				<a href="/soups/create"
					class="btn-sketch hidden sm:inline-flex items-center gap-2 font-mono text-xs">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
						stroke-linecap="round" stroke-linejoin="round">
						<path d="M12 5v14M5 12h14" />
					</svg>
					新建海龟汤
				</a>

				<a href="/my"
					class="btn-sketch hidden sm:inline-flex items-center gap-2 font-mono text-xs">
					我的汤库
				</a>

				<a href="/messages"
					class="btn-sketch hidden sm:inline-flex items-center gap-2 font-mono text-xs">
					消息
					<% if ((unreadCount || 0) > 0) { %>
						<span class="ml-1 inline-flex items-center justify-center min-w-5 h-5 px-1 bg-black text-white rounded-full text-[10px]">
							<%= unreadCount > 99 ? '99+' : unreadCount %>
						</span>
					<% } %>
				</a>

				<div class="h-6 w-px bg-neutral-200"></div>

				<!-- 用户区：用户名 + 退出图标按钮 -->
				<div class="flex items-center gap-3">
					<span class="text-sm font-medium hidden sm:inline-block">
						<%= currentUser.username %>
					</span>

				<form method="post" action="/auth/logout" style="display:inline;">
					<button
						type="submit"
						class="group relative w-9 h-9 flex items-center justify-center hover:bg-neutral-100 rounded-full transition"
						aria-label="退出登录"
					>
						<!-- logout icon -->
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
							stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
							<path d="M16 17l5-5-5-5" />
							<path d="M21 12H9" />
						</svg>

						<span
							class="pointer-events-none absolute left-1/2 top-full z-[80] mt-2 -translate-x-1/2 whitespace-nowrap rounded-md bg-black px-2.5 py-1.5 text-xs font-mono text-white opacity-0 shadow-lg transition-opacity duration-150 group-hover:opacity-100 group-focus-visible:opacity-100"
						>
							退出登录

							<span
								class="absolute left-1/2 -top-1 h-2 w-2 -translate-x-1/2 rotate-45 bg-black"
								aria-hidden="true"
							></span>
						</span>
					</button>
				</form>
				</div>

				<% if (currentUser.role==='admin' ) { %>
					<a href="/admin" class="btn-sketch font-mono text-xs">后台</a>
					<% } %>

						<% } else { %>
							<!-- 登录前：ADMIN + LOGIN（原版布局） -->
							<a href="/admin/login"
								class="flex items-center font-mono text-xs text-neutral-500 hover:text-black">
								<!-- shield icon -->
								<svg class="w-4 h-4 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor"
									stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
