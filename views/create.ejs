<!doctype html>
<html lang="zh-CN">

<head>
    <%- include('partials/head', { title }) %>
</head>

<body>
    <%- include('partials/navbar') %>

        <main class="max-w-5xl mx-auto px-4 py-10">
            <div class="flex items-start justify-between gap-6 mb-8">
                <div>
                <h1 class="font-serif font-bold text-3xl flex items-center gap-2">
                    NEW SOUP
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 21a9 9 0 0 0 9-9H3a9 9 0 0 0 9 9Z"/>
                        <path d="M7 21h10"/>
                        <path d="M19.5 12 22 6"/>
                        <path d="M16.25 3c.27.1.8.53.75 1.36-.06.83-.93 1.2-1 2.02-.05.78.34 1.24.73 1.62"/>
                        <path d="M11.25 3c.27.1.8.53.74 1.36-.05.83-.93 1.2-.98 2.02-.06.78.33 1.24.72 1.62"/>
                        <path d="M6.25 3c.27.1.8.53.75 1.36-.06.83-.93 1.2-1 2.02-.05.78.34 1.24.74 1.62"/>
                    </svg>
                </h1>
                    <p class="mt-2 font-mono text-xs text-neutral-500">
                        创建一碗新的海龟汤。公开汤需要管理员审核；私密汤会生成 24 小时有效分享码。
                    </p>
                </div>
                <a href="/" class="btn-sketch">返回</a>
            </div>

            <div class="border-2 border-black bg-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] p-6">
                <% if (error) { %>
                    <div class="mb-5 border-2 border-black bg-neutral-50 p-3 font-mono text-xs">
                        <span class="font-bold">提示：</span>
                        <%= error %>
                    </div>
                    <% } %>

                        <form method="post" action="/soups/create" class="space-y-5" id="createForm">
                            <div>
                                <div class="font-mono text-xs text-neutral-600 mb-2">标题（必填）</div>
                                <input name="title" value="<%= form.title || '' %>"
                                    class="w-full h-12 border-2 border-black rounded-none px-3 outline-none"
                                    placeholder="例如：电梯里的男人" />
                            </div>

                            <div>
                                <div class="font-mono text-xs text-neutral-600 mb-2">汤面（必填，最多1000字）</div>
                                <textarea name="surface"
                                    class="w-full border-2 border-black rounded-none p-3 min-h-[120px] resize-none outline-none"
                                    placeholder="描述你给玩家看到的表面故事" maxlength="1000"><%= form.surface || '' %></textarea>
                            </div>

                            <div>
                                <div class="font-mono text-xs text-neutral-600 mb-2">汤底（必填，最多2000字）</div>
                                <textarea name="bottom"
                                    class="w-full border-2 border-black rounded-none p-3 min-h-[140px] resize-none outline-none"
                                    placeholder="真实原因（会在翻转后解锁）" maxlength="2000"><%= form.bottom || '' %></textarea>
                            </div>


                            <div class="border-2 border-black bg-neutral-50 p-4 space-y-3">
                                <label class="inline-flex items-center gap-2 font-mono text-xs cursor-pointer">
                                    <input type="checkbox" name="has_host_manual" value="1" id="hasHostManual" <%= form.has_host_manual ? 'checked' : '' %> />
                                    有主持人手册
                                </label>
                                <div id="hostManualBox" class="<%= form.has_host_manual ? '' : 'hidden' %>">
                                    <div class="font-mono text-xs text-neutral-600 mb-2">主持人手册（勾选后必填，最多2000字）</div>
                                    <textarea name="host_manual" id="hostManualInput"
                                        class="w-full border-2 border-black rounded-none p-3 min-h-[160px] resize-y outline-none bg-white"
                                        placeholder="给主持人的补充说明、引导提示、关键线索或控场建议" maxlength="2000"><%= form.host_manual || '' %></textarea>
                                    <div class="mt-1 font-mono text-[11px] text-neutral-500">不勾选时不会保存主持人手册内容。</div>
                                </div>
                            </div>

                            <div>
                                <div class="font-mono text-xs text-neutral-600 mb-2">标签（可多选）</div>
                                <div class="flex flex-wrap gap-2">
                                    <% (tags || []).forEach((t)=> { %>
                                        <label
                                            class="inline-flex items-center gap-2 border-2 border-black px-3 py-2 font-mono text-xs cursor-pointer hover:bg-black hover:text-white transition">
                                            <input type="checkbox" name="tagIds" value="<%= t.id %>" <%=(form.tagIds ||
                                                []).includes(t.id) ? 'checked' : '' %> />
                                            <span>
                                                <%= t.name %>
                                            </span>
                                        </label>
                                        <% }) %>
                                </div>
                            </div>

                            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pt-2">
                                <label class="inline-flex items-center gap-2 font-mono text-xs cursor-pointer">
                                    <input type="checkbox" name="is_anonymous" value="1" <%=form.is_anonymous
                                        ? 'checked' : '' %> />
                                    匿名发布（隐藏作者）
                                </label>

                                <!-- ✅ 三个“真正提交”的按钮：点哪个就提交哪个 -->
                                <div class="flex flex-wrap items-center justify-end gap-2">
                                    <button type="submit" name="action" value="public"
                                        class="btn-sketch-primary h-12 px-6">
                                        公开发布
                                    </button>

                                    <button type="submit" name="action" value="private" class="btn-sketch h-12 px-6">
                                        私密分享
                                    </button>

                                    <button type="submit" name="action" value="draft" class="btn-sketch h-12 px-6">
                                        保存草稿
                                    </button>
                                </div>
                            </div>

                            <div class="font-mono text-xs text-neutral-500 leading-relaxed">
                                <div>• 公开发布：提交后进入 <span class="font-bold">待审核</span>，审核通过才会出现在公开汤池。</div>
                                <div>• 私密分享：提交后生成 <span class="font-bold">24小时有效</span> 的分享码，仅凭分享码访问。</div>
                                <div>• 保存草稿：仅你自己可预览，也可以在“我的汤库”继续管理。</div>
                            </div>
                        </form>
            </div>
        </main>

<script>
(function () {
    const checkbox = document.getElementById('hasHostManual');
    const box = document.getElementById('hostManualBox');
    const input = document.getElementById('hostManualInput');
    if (!checkbox || !box || !input) return;
    function sync() {
        box.classList.toggle('hidden', !checkbox.checked);
        input.required = checkbox.checked;
    }
    checkbox.addEventListener('change', sync);
    sync();
})();
</script>
</body>

</html>