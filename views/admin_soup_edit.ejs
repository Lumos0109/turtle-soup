<!doctype html>
<html lang="zh-CN">

<head>
	<%- include('partials/head', { title }) %>
</head>

<body>
	<%- include('partials/navbar') %>

		<main class="max-w-5xl mx-auto px-4 py-10">
			<div class="flex items-start justify-between gap-6 mb-8">
				<div>
					<h1 class="font-serif font-bold text-3xl">编辑海龟汤</h1>
					<p class="mt-2 font-mono text-xs text-neutral-500">管理员可编辑标题、汤面、汤底、匿名和标签</p>
				</div>
				<a href="/admin?tab=publicSoups" class="btn-sketch">返回</a>
			</div>

			<div class="border-2 border-black bg-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] p-6">
				<form method="post" action="/admin/soups/<%= soup.id %>/edit" class="space-y-5">
					<div>
						<div class="font-mono text-xs text-neutral-600 mb-2">标题</div>
						<input name="title" value="<%= soup.title %>"
							class="w-full h-12 border-2 border-black px-3 outline-none" />
					</div>

					<div>
						<div class="font-mono text-xs text-neutral-600 mb-2">汤面（最多1000字）</div>
						<textarea name="surface" maxlength="1000"
							class="w-full border-2 border-black p-3 min-h-[140px] outline-none"><%= soup.surface %></textarea>
					</div>

					<div>
						<div class="font-mono text-xs text-neutral-600 mb-2">汤底（最多2000字）</div>
						<textarea name="bottom" maxlength="2000"
							class="w-full border-2 border-black p-3 min-h-[160px] outline-none"><%= soup.bottom %></textarea>
					</div>

					<div class="border-2 border-black bg-neutral-50 p-4 space-y-3">
						<label class="inline-flex items-center gap-2 font-mono text-xs cursor-pointer">
							<input type="checkbox" name="has_host_manual" value="1" id="hasHostManual" <%= soup.has_host_manual ? 'checked' : '' %> />
							有主持人手册
						</label>
						<div id="hostManualBox" class="<%= soup.has_host_manual ? '' : 'hidden' %>">
							<div class="font-mono text-xs text-neutral-600 mb-2">主持人手册（勾选后必填，最多2000字）</div>
							<textarea name="host_manual" id="hostManualInput" maxlength="2000"
								class="w-full border-2 border-black p-3 min-h-[160px] outline-none bg-white"
								placeholder="给主持人的补充说明、引导提示、关键线索或控场建议"><%= soup.host_manual || '' %></textarea>
						</div>
					</div>

					<label class="inline-flex items-center gap-2 font-mono text-xs">
						<input type="checkbox" name="is_anonymous" value="1" <%=soup.is_anonymous ? 'checked' : '' %> />
						匿名发布
					</label>

					<div>
						<div class="font-mono text-xs text-neutral-600 mb-2">标签</div>
						<div class="flex flex-wrap gap-2">
							<% tags.forEach((t)=> { %>
								<label
									class="inline-flex items-center gap-2 border-2 border-black px-3 py-2 font-mono text-xs cursor-pointer hover:bg-black hover:text-white">
									<input type="checkbox" name="tagIds" value="<%= t.id %>"
										<%=selectedTagIds.includes(t.id) ? 'checked' : '' %> />
									<span>
										<%= t.name %>
											<%= t.is_hidden ? '（隐藏）' : '' %>
									</span>
								</label>
								<% }) %>
						</div>
					</div>

					<div class="flex justify-end">
						<button type="submit" class="btn-sketch-primary h-12 px-6">保存修改</button>
					</div>
				</form>
			</div>
		</main>
<script>
(function () {
	const checkbox = document.getElementById('hasHostManual');
	const box = document.getElementById('hostManualBox');
	const input = document.getElementById('hostManualInput');
	if (!checkbox || !box || !input) return;
	function sync() {
		box.classList.toggle('hidden', !checkbox.checked);
		input.required = checkbox.checked;
	}
	checkbox.addEventListener('change', sync);
	sync();
})();
</script>
</body>

</html>