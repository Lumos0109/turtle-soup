NODE_ENV=development
PORT=3000

SITE_TITLE=TURTLE-SOUP
BASE_URL=http://localhost:3000
DOMAIN=localhost

# 开发环境也建议换成长随机字符串，至少 32 位。
SESSION_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# 首次初始化数据库时会创建这个管理员账号；之后请用脚本改密码。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password

CREATE_DEMO_DATA=1
TRUST_PROXY=0
COOKIE_SECURE=0

SHARE_CODE_EXPIRE_HOURS=24

FEEDBACK_MAX_TEXT_LEN=100
FEEDBACK_MAX_USER_TEXT_MESSAGES=5
FEEDBACK_MAX_IMAGES_PER_THREAD=3
FEEDBACK_MAX_IMAGE_BYTES=2097152

# 房间系统限制：2核4G先保守配置，后续看实际并发再调大。
ROOM_MAX_ACTIVE=10
ROOM_MAX_MEMBERS=12
ROOM_MAX_HISTORY=200
ROOM_WAITING_IDLE_MINUTES=30
ROOM_PLAYING_IDLE_MINUTES=180
ROOM_MEMBER_OFFLINE_SECONDS=35
ROOM_HINT_MAX_IMAGES=5
ROOM_HINT_MAX_IMAGE_BYTES=2097152


# LLM 主持人，可不填；不填时主持人功能会提示未配置。
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-你的真实API密钥
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_MS=30000
LLM_DEBUG=1

TZ=Asia/Shanghai
TIME_ZONE=Asia/Shanghai
